NODE_ENV=development

PORT=3000
# Public API host (no trailing slash, no /api). Uploads are served at {API_URL}/uploads/...
API_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# GOOGLE SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mr_boss_realty
SESSION_SECRET=

OPENAI_API_KEY=

# AI chat usage limits (legacy env fallback — OTP question limit is now Admin → Settings → Website)
AI_CHAT_MESSAGE_LIMIT=12
AI_CHAT_TOKEN_LIMIT=12000

# Deprecated: OTP is controlled by Admin website setting `otp_trigger_question_count` (empty = disabled)
AI_OTP_VERIFICATION_ENABLED=false

# Public website URL used for sitemap.xml, robots.txt, absolute listing links, and CORS
WEBSITE_URL=http://localhost:5174
# Optional extra browser origins (comma-separated), e.g. preview deploys
# CORS_ORIGINS=https://preview.mrbossrealty.com

# Cloudflare R2 (S3-compatible object storage for property/unit images)
# Without R2, uploads fall back to local ./uploads (wiped on many deploys).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Public object URL base (no trailing slash). Required for CDN delivery.
# Local/dev public bucket URL:
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Production custom domain:
# R2_PUBLIC_URL=https://images.mrbossrealty.com

# SMS OTP — choose ONE provider below
# Option A: Twilio (https://www.twilio.com)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+15005550006

# Option B: Semaphore (Philippines — https://semaphore.co)
# SEMAPHORE_API_KEY=
# SEMAPHORE_SENDER_NAME=MRBOSS

# Lead contact encryption + hashing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
LEADS_ENCRYPTION_KEY=
LEADS_HASH_KEY=
